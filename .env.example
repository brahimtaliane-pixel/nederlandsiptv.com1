# ============================================================
# IPTV Nederland - Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase — https://supabase.com (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Optional: scripts/run-schema.mjs direct Postgres (Settings → Database password)
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=your_project_ref

# Optional: admin session signing if you prefer not to use service role key
# ADMIN_SESSION_SECRET=

# Admin login email (defaults to legacy address if unset)
# ADMIN_EMAIL=contact@nederlandsiptv.com

# Resend — https://resend.com (for transactional emails)
RESEND_API_KEY=re_your_api_key

# Site URL (no trailing slash) — drives SITE_CONFIG.url, domain, and default contact@ email
# Production:
NEXT_PUBLIC_SITE_URL=https://www.nederlandsiptv.com
#
# Local development — set this to whatever you use in the browser so metadata / JSON-LD match.
# If you omit it while running `next dev`, it defaults to http://localhost:<PORT> (e.g. :3000).
# Examples:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# NEXT_PUBLIC_SITE_URL=https://nederlandsiptv.local

# Optional: override contact email (default is contact@<your domain>)
# NEXT_PUBLIC_CONTACT_EMAIL=contact@nederlandsiptv.com

# Google Analytics (GA4 Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Crisp Live Chat — https://crisp.chat (Website ID)
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-website-id
